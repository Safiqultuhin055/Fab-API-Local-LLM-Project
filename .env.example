# ===== Local Ollama AI Gateway — environment template =====
# Copy to .env and fill real values. NEVER commit .env.

# --- App ---
APP_NAME="Local Ollama AI Gateway"
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
DEBUG=true

# --- Database ---
# Automatic selection: if SQL Server (MSSQL_* below) is configured AND reachable
# at startup, the gateway uses it; otherwise it falls back to this local SQLite.
DATABASE_URL=sqlite+aiosqlite:///./ai_gateway.db

# --- SQL Server (optional primary DB; auto-fallback to SQLite if unreachable) ---
# Leave MSSQL_HOST empty to disable and always use SQLite above.
# Needs ODBC Driver 18 installed (Docker image installs it; on Windows install MSODBCSQL18).
MSSQL_HOST=192.168.153.248
MSSQL_PORT=1433
MSSQL_DATABASE=ai_gateway
MSSQL_USER=sa
MSSQL_PASSWORD=CHANGE_ME_sql_server_password
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
DB_PROBE_TIMEOUT=3.0

# You can still bypass MSSQL_* entirely by setting DATABASE_URL to a full async URL, e.g.:
# DATABASE_URL=mssql+aioodbc://sa:Passw0rd!@localhost:1433/ai_gateway?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# --- Security ---
# HMAC secret used to hash API keys. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
HMAC_SECRET=CHANGE_ME_long_random_secret
# Static admin key guarding the programmatic /admin/* JSON API (X-ADMIN-KEY header).
ADMIN_API_KEY=CHANGE_ME_admin_key
# Dashboard UI login (username + password) for /admin/ui.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- CORS (comma-separated allow-list; no wildcard with credentials) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- LLM backend: ollama | openai (LM Studio uses openai) ---
LLM_BACKEND=ollama

# --- Ollama ---
# Ollama runs on the "pele" server only. The gateway auto-picks the URL by host:
#   - on pele (this machine holds PELE_IP)  -> OLLAMA_BASE_URL (pele localhost)
#   - on a local PC                          -> OLLAMA_REMOTE_URL (pele over LAN)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_REMOTE_URL=http://192.168.153.250:11434
PELE_IP=192.168.153.250
OLLAMA_TIMEOUT_SECONDS=120
DEFAULT_MODEL=llama3.1
# Cloud model example (Ollama cloud): needs `ollama signin` + `ollama pull qwen3-coder:480b-cloud`,
# raise OLLAMA_TIMEOUT_SECONDS=300, and set EMBEDDING_MODEL to a local embed model for RAG.
# DEFAULT_MODEL=qwen3-coder:480b-cloud
# EMBEDDING_MODEL=nomic-embed-text

# --- Rate limiting ---
# Backend: memory | redis  (redis recommended for prod/multi-worker)
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
# Default tier for new keys: free | pro | enterprise
DEFAULT_TIER=free

# --- Logging / privacy ---
LOG_PROMPT_BODIES=true             # store prompt/response text in request_logs
LOG_BODY_MAX_CHARS=2000            # truncate stored bodies
LOG_RETENTION_DAYS=90
